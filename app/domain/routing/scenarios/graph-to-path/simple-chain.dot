// Four lanes connected end-to-end in a straight chain.
// The walk starts at A and must accumulate 400 m to succeed.
//
//   A --200m-- B --200m-- C --200m-- D --200m-- E
//
graph simple_chain {
  graph [
    description = "Straight chain of four connected lanes",
    start = "A",
    minDist = 400,
    maxDist = 5000,
    expect_minRoutes = 1,
    expect_hasGap = "false",
    expect_minCoverage = "1.0"
  ]

  A -- B [distance=200, type=lane]
  B -- C [distance=200, type=lane]
  C -- D [distance=200, type=lane]
  D -- E [distance=200, type=lane]
}
