// One-way from A to E through a fork at B.
// Two paths of equal length exist — Dijkstra returns the single shortest (either branch).
//
//   A --200m-- B --200m-- C --200m-- E
//              |
//              +--200m-- D --200m-- E
//
graph one_way_branching {
  graph [
    description = "One-way from A to E via two different branches through the fork at B",
    start = "A",
    end = "E",
    minDist = 0,
    maxDist = 5000,
    expect_any_route = "A,B,C,E;A,B,D,E"
  ]

  A -- B [distance=200, type=lane]
  B -- C [distance=200, type=lane]
  C -- E [distance=200, type=lane]
  B -- D [distance=200, type=lane]
  D -- E [distance=200, type=lane]
}
