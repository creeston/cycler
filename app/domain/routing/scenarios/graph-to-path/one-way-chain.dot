// One-way route from A to E along a straight chain.
// Only one simple path exists, so exactly one route is expected.
//
//   A --200m-- B --200m-- C --200m-- D --200m-- E
//
graph one_way_chain {
  graph [
    description = "One-way from A to E along a straight connected chain",
    start = "A",
    end = "E",
    minDist = 0,
    maxDist = 5000,
    expect_route = "A,B,C,D,E"
  ]

  A -- B [distance=200, type=lane]
  B -- C [distance=200, type=lane]
  C -- D [distance=200, type=lane]
  D -- E [distance=200, type=lane]
}
